# ================================================
# CONFIGURAÇÕES — renomeie este arquivo para .env
# ================================================

# Supabase — pegue em: supabase.com > seu projeto > Settings > API
SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Porta do servidor local
PORT=3001

# Intervalo mínimo entre envios em ms (padrão 10 segundos)
DELAY_MIN_MS=10000

# Intervalo máximo entre envios em ms (padrão 20 segundos)  
DELAY_MAX_MS=20000
